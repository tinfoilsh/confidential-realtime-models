# Runtime deps for the thin FastAPI proxy in front of vLLM.
# librosa/scipy/pydub were dropped after vLLM 0.20 took over native M4A/WebM
# decoding — see Dockerfile for context. soundfile is kept because
# mistral-common[soundfile] is required by the Voxtral model loader at
# runtime, even though the proxy itself doesn't decode audio anymore.

fastapi
httpx
uvicorn
websockets
soundfile
